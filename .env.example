# Copy to .env and fill in. All paths below are PLACEHOLDERS — point them at
# your own install locations. The harness reads these from the environment.

# ---- Model + judge (required) -------------------------------------------
# Drives the deepseek-v4-pro backends AND the shared rubric judge, so every
# agent is scored by the same model.
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# ---- Dataset (required) --------------------------------------------------
# BiomniBench-DA is a gated dataset; a HF token with access is needed to fetch
# the task inputs + rubrics. See docs/ for the reconstruction path.
HF_TOKEN=hf_...

# ---- Scientific kernel (shared by omicos / synsci / ai4s / wisp) ---------
# A python env carrying the scientific stack (scanpy/omicverse/etc.). The
# agents execute generated code in this interpreter.
OMICOS_KERNEL_PYTHON=/path/to/scientific-env/bin/python

# ---- omicos backend ------------------------------------------------------
# omicos-core + omicos-admin are PRIVATE — the omicos backend is not externally
# runnable. omicos-biomnibench (dataset staging + judge) is public.
OMICOS_BIN=/path/to/omicos-core/target/release/omicos
OMICOS_ADMIN_ROOT=/path/to/omicos-admin
OMICOS_BIOMNIBENCH_ROOT=/path/to/omicos-biomnibench   # public repo

# ---- Competitor backends (each optional; only needed to run that backend) --
# EvoScientist: `EvoSci` on PATH, or an absolute path / apptainer wrapper.
# EVOSCI_BIN=/path/to/EvoSci                       # or scripts/evosci-apptainer.sh
# biomni: python of the biomni conda env (biomni installed there).
# BIOMNI_PYTHON=/path/to/biomni-env/bin/python
# Container backends resolve their binaries via the ${VAR:-default} defaults in
# scripts/*.sh — override SIF / *_BIN there or via env. See docs/running-competitors.md.
